APP_NAME="SALTO Battery Monitor"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Application database (the monitor's own data) ---
DB_CONNECTION=mysql
DB_HOST=appdb
DB_PORT=3306
DB_DATABASE=salto_monitor
DB_USERNAME=salto
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# --- SALTO Space MS SQL Server (READ-ONLY) ---
SALTO_DB_HOST=
SALTO_DB_PORT=1433
SALTO_DB_DATABASE=ProAccessSpace
SALTO_DB_USERNAME=
SALTO_DB_PASSWORD=
SALTO_DB_ENCRYPT=yes
SALTO_DB_TRUST_CERT=true

# Schema mapping — set these after running `php artisan salto:discover`.
SALTO_LOCK_TABLE=tb_DOOR
SALTO_COL_ID=ID
SALTO_COL_NAME=NAME
SALTO_COL_LOCATION=NAME
SALTO_COL_BATTERY=BATTERY_STATUS
SALTO_COL_LASTSEEN=LAST_UPDATE
# SALTO_RAW_SQL=

# --- Dashboard admin login (seeded on first boot) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password

# --- Monitoring / alerts ---
POLL_MINUTES=15
REMINDER_HOURS=24
NOTIFY_ON_RECOVERY=true
ALERT_EMAIL_ENABLED=true
ALERT_WHATSAPP_ENABLED=true
ALERT_EMAILS=
ALERT_WHATSAPP=

# --- WhatsApp Business Cloud API (Meta) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_TEMPLATE_LOW=battery_low_alert
WHATSAPP_TEMPLATE_FLAT=battery_flat_alert
WHATSAPP_TEMPLATE_LOCALE=en

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
